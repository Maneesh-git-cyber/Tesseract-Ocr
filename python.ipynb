import pytesseract
from PIL import Image

# 1. Load the image of your Homework 1
# Replace 'hw1_image.png' with your actual image file name
image_path = 'hw1_image.png'

try:
    img = Image.open(image_path)
    
    # 2. Use Tesseract to extract the text
    print("Extracting text from HW1...")
    extracted_text = pytesseract.image_to_string(img)
    
    # 3. Print the result
    print("\n--- Extracted Soft Copy ---")
    print(extracted_text)
    
    # Optional: Save the extracted text to a text file
    with open('HW1_softcopy.txt', 'w') as f:
        f.write(extracted_text)
        print("\n(Text successfully saved to HW1_softcopy.txt)")

except FileNotFoundError:
    print(f"Error: Could not find the image file '{image_path}'. Please check the name and path.")
